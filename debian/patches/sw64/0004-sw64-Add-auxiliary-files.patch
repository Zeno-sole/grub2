+ * Select function type and registers
+ */
+#define mask	$0
+#define divisor	$1
+#define compare $28
+#define tmp1	$3
+#define tmp2	$4
+
+#define DIV
+#define INTSIZE
+
+#undef DIV_ONLY
+#undef MOD_ONLY
+#undef func
+#undef modulus
+#undef quotient
+#undef GETSIGN
+#undef STACK
+#undef ufunction
+#undef sfunction
+#undef LONGIFY
+#undef SLONGIFY
+
