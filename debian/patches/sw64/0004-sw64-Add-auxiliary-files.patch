+     fstd      $f2, JB_F2*8(a0)
+     fstd      $f3, JB_F3*8(a0)
+     fstd      $f4, JB_F4*8(a0)
+     fstd      $f5, JB_F5*8(a0)
+     fstd      $f6, JB_F6*8(a0)
+     fstd      $f7, JB_F7*8(a0)
+     fstd      $f8, JB_F8*8(a0)
+     fstd      $f9, JB_F9*8(a0)
+     ldi       a0, 0($31)
+     ret
+
+FUNCTION(grub_longjmp)
+     mov       a1, v0
+     ldl       s0, JB_S0*8(a0)
+     ldl       s1, JB_S1*8(a0)
+     ldl       s2, JB_S2*8(a0)
+     ldl       s3, JB_S3*8(a0)
+     ldl       s4, JB_S4*8(a0)
+     ldl       s5, JB_S5*8(a0)
+     ldl       ra, JB_PC*8(a0)
+     ldl       fp, JB_FP*8(a0)
+     ldl       t0, JB_SP*8(a0)
+     fldd      $f2, JB_F2*8(a0)
+     fldd      $f3, JB_F3*8(a0)
+     fldd      $f4, JB_F4*8(a0)
+     fldd      $f5, JB_F5*8(a0)
+     fldd      $f6, JB_F6*8(a0)
+     fldd      $f7, JB_F7*8(a0)
+     fldd      $f8, JB_F8*8(a0)
+     fldd      $f9, JB_F9*8(a0)
+     seleq     v0, 1, v0, v0
+     mov       t0, sp
+     ret
